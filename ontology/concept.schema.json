{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JinnZ2/Polyhedral-Intelligence/ontology/concept.schema.json",
  "title": "Polyhedral-Intelligence ontological concept",
  "description": "Structured form of one concept from Ontology.md. Captures parallel definitions across Western and Relational/Indigenous frameworks, plus hidden variables that Western framings tend to miss. License: CC0-1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "frameworks",
    "hidden_variables",
    "translation_protocol",
    "related_concepts",
    "version",
    "license"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Lowercase snake_case identifier matching the file stem."
    },
    "name": { "type": "string", "minLength": 1 },
    "source_md": { "type": "string", "description": "Path to the canonical prose source." },
    "frameworks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["western", "relational"],
      "properties": {
        "western": { "$ref": "#/$defs/framework" },
        "relational": { "$ref": "#/$defs/framework" }
      }
    },
    "functional_comparison": {
      "type": "array",
      "description": "Per-aspect contrast table from Ontology.md.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["aspect", "western", "relational"],
        "properties": {
          "aspect": { "type": "string" },
          "western": { "type": "string" },
          "relational": { "type": "string" }
        }
      }
    },
    "hidden_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["relational", "temporal", "field", "embodied", "systemic"]
          },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "why_western_misses_it": { "type": "string" }
        }
      }
    },
    "translation_protocol": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "when_to_translate": { "type": "string" },
        "how": { "type": "string" },
        "examples": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "related_concepts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "string" },
    "license": { "type": "string" }
  },
  "$defs": {
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definition"],
      "properties": {
        "definition": { "type": "string" },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
